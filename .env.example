# Example environment configuration. Copy to .env and adjust as needed.
# Keep this file secret-free. The defaults below work for local development,
# so a .env is optional for the current read-only slice.

# --- Active in the current slice ------------------------------------------

# Display timezone for the frontend (data is stored/served in UTC).
APP_TIMEZONE=Europe/London

# Allowed CORS origins for the backend (dev frontend).
CORS_ORIGINS=["http://localhost:5173"]

# Positions data source. "sample" reads the bundled CSV under data/sample/.
DATA_SOURCE_MODE=sample

# Base URL the frontend uses for API calls. Defaults to "/api/v1", which the
# Vite dev server proxies to the backend; set an absolute URL for other setups.
VITE_API_BASE_URL=/api/v1

# --- Live market slice -----------------------------------------------------
# Market data source. "yahoo" fetches real prices via yfinance (no key needed);
# "synthetic" keeps the offline illustrative generator (no DB, no network).
MARKET_SOURCE=yahoo

# Persisted market history. Put the real value in backend/.env (git-ignored),
# NOT here. Neon example (note the "+psycopg" driver and sslmode=require):
# DATABASE_URL=postgresql+psycopg://USER:PASSWORD@ep-xxxx.eu-central-1.aws.neon.tech/neondb?sslmode=require

# --- Deferred (not used yet) ----------------------------------------------
# DATA_SOURCE_URL=
# ALERT_CONFIG_PATH=
# OIDC_ISSUER_URL=
# OIDC_CLIENT_ID=
